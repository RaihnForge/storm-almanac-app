{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "overlay",
  "description": "Capabilities for the transparent overlay POC windows",
  "windows": ["overlay-interactive", "overlay-clickthrough"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:webview:default"
  ]
}
